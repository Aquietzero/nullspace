// ============================================================
// NullSpace — Monochrome Geek Theme
// 黑白为主，极简留白，等宽字体点缀极客感
// ============================================================

// --- Color Palette ---
accent = #000
accentLight = #444
accentBg = #f5f5f5
borderColor = #e0e0e0
codeBg = #f7f7f7
codeColor = #333

// Per-post theme color overrides (keep for existing posts)
blue = #477DA5
blueBg = #E9F3F7
green = #548064
greenBg = #EEF3ED
purple = #A48BBE
purpleBg = #F6F3F8

themeColor = accent
themeColorBg = accentBg

// --- Hide Headband (top bar) ---
.headband
  display: none

// --- Base ---
body
  color: #1a1a1a
  line-height: 1.75
  letter-spacing: 0.01em
  -webkit-font-smoothing: antialiased
  -moz-osx-font-smoothing: grayscale

::selection
  background: #000
  color: #fff

a
  color: #1a1a1a
  text-decoration-color: #ccc
  text-underline-offset: 3px
  transition: all 0.15s ease
  &:hover
    color: #000
    text-decoration-color: #000

strong
  color: #000
  font-weight: 700

// --- Site Header / Brand ---
.site-title
  font-weight: 900
  letter-spacing: 0.04em

.brand
  background: transparent
  color: #000
  font-size: 1.5em
  text-decoration: none
  border-bottom: 2px solid #000
  padding-bottom: 2px
  &:hover
    color: #555

.site-subtitle
  color: #999
  font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
  font-size: 0.75em
  letter-spacing: 0.08em
  text-transform: uppercase

// --- Navigation ---
.menu
  .menu-item
    a
      color: #666
      font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
      font-size: 0.85em
      letter-spacing: 0.04em
      text-transform: lowercase
      border-bottom: none
      &:hover
        color: #000
      &.active,
      &:active
        color: #000
        font-weight: 700

// --- Pagination ---
.pagination
  border: none
  .page-number
    border: none
    color: #999
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
    &.current
      background: #000
      color: #fff
      border-radius: 0
  .extend
    border: none

// --- Archive List ---
.collection-title
  display: none

.posts-collapse .post-content
  .collection-year
    margin: 40px 0 15px 0
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
    font-weight: 700

  .post-header
    color: #1a1a1a
    margin: 12px 2px 0
    display: flex
    align-items: baseline
    .post-title
      flex: 1
      min-width: 0
      overflow: hidden
      text-overflow: ellipsis
      white-space: nowrap

  .archive-category-tag
    flex-shrink: 0
    margin-left: 12px
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
    font-size: 0.7em
    color: #999
    text-decoration: none
    border-bottom: none !important
    white-space: nowrap
    &:hover
      color: #000

// --- Post ---
.post-block
  h1.post-title
    font-size: 2em
    font-weight: 900 !important
    letter-spacing: -0.02em
    line-height: 1.2

  .post-meta
    color: #999
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
    font-size: 0.8em

  .post-body
    text-align: left

    h1, h2, h3, h4, h5, h6
      font-weight: 800
      color: #000
      letter-spacing: -0.01em

    h2
      margin-top: 0.6em

    h3
      margin-top: 1.8em

    p
      margin-bottom: 1.2em

    table
      font-size: 0.84em
      font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
      border-collapse: collapse
      border: none
      width: 100%
      margin: 1.5em 0
      thead
        tr
          border-bottom: 2px solid #000
      th
        background: none
        font-weight: 700
        text-transform: uppercase
        letter-spacing: 0.06em
        font-size: 0.85em
        color: #666
        padding: 6px 14px 8px
        border: none
        text-align: left
      td
        padding: 7px 14px
        border: none
        border-bottom: 1px solid #eee
        color: #333
      tbody
        tr
          transition: background 0.1s ease
          &:hover
            background: #fafafa
          &:last-child td
            border-bottom: none

    aside
      background: none
      padding: 20px 0 12px
      border: none
      border-top: 1px solid #d0d0d0
      border-bottom: 1px solid #d0d0d0
      border-radius: 0
      margin: 1.5em 0
      position: relative
      font-size: 0.92em
      color: #444
      &::before
        content: 'NOTE'
        position: absolute
        top: 0
        left: 12px
        transform: translateY(-50%)
        background: #fff
        padding: 0 8px
        font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
        font-size: 0.7em
        font-weight: 700
        letter-spacing: 0.12em
        color: #aaa
      &[data-title]::before
        content: attr(data-title)
      &[data-title="注意"]
        color: #a63d40
        border-top-color: #a63d40
        border-bottom-color: #a63d40
        &::before
          color: #a63d40
        strong
          color: inherit
      p
        padding: 0
        margin: 0

    // Inline code: bare monospace, no box
    code
      color: #000
      background: none
      font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
      font-size: 0.86em
      padding: 0
      border: none
      border-radius: 0
      text-decoration: none !important

    em
      font-style: normal
      border-bottom: solid 1px #999

    // Code blocks: clean, no bg, top/bottom dividers only
    .highlight
      background: none
      border: none
      border-top: 1px solid #e0e0e0
      border-bottom: 1px solid #e0e0e0
      border-radius: 0
      margin: 1.5em 0
      padding: 4px 0
      overflow-x: auto
      table
        border: none
        background: none
        td
          border: none
          background: none
        tr
          border: none
          background: none
          &:hover
            background: none
        .gutter
          border-right: none
          pre
            color: #ccc

    figcaption
      font-weight: normal !important
      line-height: 1.2
      text-align: left
      strong
        color: #999 !important

    .code
      font-size: 0.9em
      font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace

    // Blockquote
    blockquote
      border-left: 3px solid #000
      color: #555
      padding-left: 1em
      margin-left: 0

    // Horizontal rule
    hr
      border: none
      border-top: 1px solid borderColor
      margin: 2em 0

    // Images
    img
      border-radius: 2px

  // Copyright
  .post-copyright
    ul
      border-left: solid 3px #000
    font-size: 0.8em

// --- Related Posts ---
.posts-related
  margin: 50px 0
  border-top: 1px solid borderColor
  padding-top: 30px
  .popular-posts-title
    font-size: 1em
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
    text-transform: uppercase
    letter-spacing: 0.06em
    color: #999
  .popular-posts
    list-style-type: none
    padding-left: 0
    .popular-posts-item
      line-height: 1.6
      margin-bottom: 10px
      .popular-posts-link
        opacity: 1
        border-bottom: none
        display: flex
        flex-direction: column
        &:hover .popular-posts-title
          color: #000
      .popular-posts-title
        font-size: 1em
        color: #333
      .popular-posts-time
        opacity: 0.5
        font-size: 0.8em
        font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
        margin-bottom: -5px
        text-decoration: none !important

// --- Sidebar: Monochrome Geek Style ---
.sidebar
  background: #fff
  box-shadow: none !important
  border-right: 1px solid #e0e0e0

  a
    color: #555
    border-bottom: none
    &:hover
      color: #000
      border-bottom: none

.sidebar-dimmer
  background: rgba(0, 0, 0, 0.3)

// 侧边栏导航标签（目录 / 站点概览）
.sidebar-nav
  li
    color: #999
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
    font-size: 0.8em
    letter-spacing: 0.04em
    text-transform: lowercase
    &:hover
      color: #000

.sidebar-toc-active .sidebar-nav-toc,
.sidebar-overview-active .sidebar-nav-overview
  color: #000
  border-bottom-color: #000
  &:hover
    color: #000

// TOC 目录
.post-toc
  ol
    a
      color: #666
      border-bottom: none
      font-size: 0.85em
      transition: color 0.15s ease
      &:hover
        color: #000

  .nav
    .active > a
      color: #000
      border-bottom-color: #000
      font-weight: 600

    .active-current > a
      color: #000
      &:hover
        color: #000

// 站点概览
.site-author-image
  border-color: #e0e0e0 !important

.site-author-name
  color: #000
  font-weight: 800

.site-description
  color: #999
  font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
  font-size: 0.8em
  letter-spacing: 0.02em

// 文章/分类/标签计数
.site-state
  border: none

  a
    color: #666
    &:hover
      color: #000

  .site-state-item
    border: none
    padding: 0 12px

  .site-state-item-count
    color: #000
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
    font-weight: 700

  .site-state-item-name
    color: #999
    font-size: 0.8em

// 社交链接
.links-of-author
  a
    color: #666
    border-bottom: none !important
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace
    &:hover
      color: #000

    &::before
      background: #000 !important

// 侧边栏切换按钮
.sidebar-toggle
  .toggle-line
    background: #666
  &:hover .toggle-line
    background: #000

// --- Book Cover ---
.book-cover
  margin: 0 auto
  width: 40%
  img
    border-radius: 2px
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08)
  .book-authors
    font-size: 0.8em

// --- Footer ---
.with-love
  color: #000

// --- Responsive ---
@media (max-width: 991px)
  .math.display
    font-size: 0.8em

  .post-block
    .post-body
      img
        width: 95% !important
      figure
        margin-inline-start: 10px !important
        margin-inline-end: 10px !important
        &.book-cover
          margin: 0 auto !important

      .code
        font-size: 0.7em

// --- Per-post Color Themes (backward compat) ---
.theme-color-blue
  code
    color: blue !important
    background: none !important
    text-decoration: none !important

.theme-color-green
  code
    color: green !important
    background: none !important
    text-decoration: none !important

.theme-color-purple
  code
    color: purple !important
    background: none !important
    text-decoration: none !important
